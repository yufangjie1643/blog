---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<Layout title={title} description={description}>
  <article>
    {heroImage && <img src={heroImage} alt={title} class="hero-image" />}
    <div class="meta">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {updatedDate && (
        <span class="updated">
          (更新于 {updatedDate.toLocaleDateString('zh-CN')})
        </span>
      )}
    </div>
    <h1>{title}</h1>
    <div class="content">
      <slot />
    </div>
  </article>
</Layout>

<style>
  .hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1.5rem;
  }

  .meta {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .updated {
    margin-left: 0.5rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    color: var(--accent);
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(ul, ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(code) {
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Fira Code', monospace;
  }

  .content :global(pre) {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }
</style>
