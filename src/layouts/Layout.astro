---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '西南交通大学力学与航空航天学院 · 个人学术博客' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">🚀 FJ Space</a>
        <div class="links">
          <a href="/">首页</a>
          <a href="/blog">文章</a>
          <a href="/projects">项目</a>
          <a href="/about">关于</a>
          <a href="https://github.com/yufangjie1643" target="_blank" rel="noopener" class="github-link">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© {new Date().getFullYear()} yufangjie1643 · 西南交通大学力学与航空航天学院</p>
      <p class="footer-tech">Built with Astro &middot; Hosted on GitHub Pages</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --accent: #0056b3;
    --accent-light: #4a90d9;
    --bg: #ffffff;
    --bg-secondary: #f8fafc;
    --text: #0f172a;
    --text-secondary: #475569;
    --border: #e2e8f0;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --accent: #60a5fa;
      --accent-light: #93c5fd;
      --bg: #0f172a;
      --bg-secondary: #1e293b;
      --text: #f8fafc;
      --text-secondary: #94a3b8;
      --border: #334155;
    }
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    line-height: 1.6;
  }

  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg-secondary);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  nav {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .links a {
    padding: 0.25rem 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
    border-radius: 4px;
  }

  .links a:hover {
    color: var(--accent);
  }

  .github-link {
    display: flex;
    align-items: center;
    margin-left: 0.5rem;
  }

  main {
    flex: 1;
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    border-top: 1px solid var(--border);
  }

  .footer-tech {
    margin-top: 0.25rem;
    font-size: 0.8rem;
    opacity: 0.7;
  }
</style>
