---
interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  lang?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  seoTitle,
  description = '西南交通大学力学与航空航天学院 · 个人学术博客',
  canonicalUrl,
  ogImage,
  lang = 'zh-CN',
  ogType = 'website',
} = Astro.props;
const pageTitle = seoTitle ?? title;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/daily-paper', label: '每日论文精读' },
  { href: '/projects', label: '项目' },
  { href: '/about', label: '关于' },
];

const normalizePath = (path: string) => {
  const clean = path.replace(/\/$/, '');
  return clean === '' ? '/' : clean;
};

const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <script is:inline>
      const formatClientTimes = () => {
        const formatter = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          hour12: false,
          timeZoneName: 'short',
        });

        document.querySelectorAll('time[data-timestamp]').forEach((node) => {
          const timestamp = Number(node.getAttribute('data-timestamp'));
          if (!Number.isFinite(timestamp)) return;
          node.textContent = formatter.format(new Date(timestamp * 1000));
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', formatClientTimes);
      } else {
        formatClientTimes();
      }
    </script>
  </head>
  <body>
    <a href="#main" class="skip-nav">跳到主要内容</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="主导航">
        <a href="/" class="logo" aria-label="FJ Space 首页">
          <span class="logo-mark">FJ</span>
          <span class="logo-text">
            <strong>FJ Space</strong>
            <small>Mechanics Notes</small>
          </span>
        </a>
        <div class="links">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[{ active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <a
            href="https://github.com/yufangjie1643"
            target="_blank"
            rel="noopener"
            class="github-link"
            aria-label="GitHub: yufangjie1643"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
          </a>
        </div>
      </nav>
    </header>
    <main id="main" class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>yufangjie1643</strong>
        <span>西南交通大学力学与航空航天学院</span>
      </div>
      <p>© {new Date().getFullYear()} · Built with Astro · Hosted on GitHub Pages</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f4efe6;
    --bg-elevated: #fffaf1;
    --surface: rgba(255, 250, 241, 0.82);
    --surface-strong: #fffdf8;
    --text: #17211d;
    --text-secondary: #66706a;
    --text-soft: #8a8176;
    --accent: #b85b2b;
    --accent-light: #da7a3e;
    --accent-2: #1b756f;
    --accent-3: #293f67;
    --border: rgba(28, 38, 33, 0.14);
    --border-strong: rgba(28, 38, 33, 0.26);
    --shadow: 0 24px 70px rgba(68, 48, 28, 0.13);
    --shadow-soft: 0 10px 32px rgba(68, 48, 28, 0.1);
    --radius: 8px;
    --radius-sm: 6px;
    --max: 1120px;
    --prose: 760px;
    --ease: cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      color-scheme: dark;
      --bg: #11120f;
      --bg-elevated: #191a16;
      --surface: rgba(27, 28, 24, 0.86);
      --surface-strong: #202119;
      --text: #f4efe4;
      --text-secondary: #b8b2a7;
      --text-soft: #918a80;
      --accent: #ee9a61;
      --accent-light: #ffc28d;
      --accent-2: #5bc4ba;
      --accent-3: #9db7ef;
      --border: rgba(244, 239, 228, 0.14);
      --border-strong: rgba(244, 239, 228, 0.28);
      --shadow: 0 24px 70px rgba(0, 0, 0, 0.36);
      --shadow-soft: 0 10px 32px rgba(0, 0, 0, 0.28);
    }
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    min-width: 320px;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    line-height: 1.65;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 16% 8%, rgba(184, 91, 43, 0.14), transparent 28rem),
      radial-gradient(circle at 88% 18%, rgba(27, 117, 111, 0.13), transparent 24rem),
      linear-gradient(135deg, rgba(255, 250, 241, 0.9), transparent 34rem),
      var(--bg);
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(29, 39, 34, 0.045) 0,
        rgba(29, 39, 34, 0.045) 1px,
        transparent 1px,
        transparent 72px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(29, 39, 34, 0.035) 0,
        rgba(29, 39, 34, 0.035) 1px,
        transparent 1px,
        transparent 72px
      );
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.95), transparent 78%);
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.38;
    background:
      repeating-linear-gradient(
        -22deg,
        transparent 0,
        transparent 13px,
        rgba(184, 91, 43, 0.055) 13px,
        rgba(184, 91, 43, 0.055) 14px
      );
    mask-image: radial-gradient(circle at 75% 10%, black, transparent 34rem);
  }

  ::selection {
    background: rgba(184, 91, 43, 0.22);
  }

  img,
  video,
  canvas,
  svg {
    max-width: 100%;
    height: auto;
  }

  a {
    color: var(--accent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    overflow-wrap: break-word;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 58%, transparent);
    outline-offset: 3px;
  }

  .skip-nav {
    position: fixed;
    left: 1rem;
    top: 1rem;
    z-index: 100;
    transform: translateY(-140%);
    padding: 0.7rem 1rem;
    border-radius: var(--radius-sm);
    background: var(--text);
    color: var(--bg);
    text-decoration: none;
    transition: transform 180ms var(--ease);
  }

  .skip-nav:focus {
    transform: translateY(0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-elevated) 78%, transparent);
    backdrop-filter: blur(18px);
  }

  .site-nav {
    width: min(100%, var(--max));
    margin: 0 auto;
    padding: 0.85rem clamp(1rem, 3vw, 1.6rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
    color: var(--text);
    text-decoration: none;
  }

  .logo-mark {
    width: 2.5rem;
    height: 2.5rem;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, rgba(184, 91, 43, 0.16), transparent),
      var(--surface-strong);
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-weight: 800;
    letter-spacing: 0;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.28);
    flex: 0 0 auto;
  }

  .logo-text {
    display: grid;
    gap: 0.05rem;
    line-height: 1.1;
  }

  .logo-text strong {
    font-size: 0.98rem;
    letter-spacing: 0;
  }

  .logo-text small {
    color: var(--text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.35rem;
    min-width: 0;
  }

  .links a {
    min-height: 2.4rem;
    padding: 0.45rem 0.72rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.92rem;
    line-height: 1;
    transition:
      color 180ms var(--ease),
      border-color 180ms var(--ease),
      background 180ms var(--ease),
      transform 180ms var(--ease);
  }

  .links a:hover,
  .links a.active {
    color: var(--text);
    border-color: var(--border);
    background: rgba(255, 255, 255, 0.32);
  }

  .links a:hover {
    transform: translateY(-1px);
  }

  .github-link {
    width: 2.4rem;
    padding-inline: 0;
    color: var(--accent-2);
  }

  .site-main {
    flex: 1;
    width: min(100%, var(--max));
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2rem) clamp(1rem, 3vw, 1.6rem) clamp(3rem, 7vw, 5rem);
    min-width: 0;
  }

  .site-footer {
    width: min(100%, var(--max));
    margin: 0 auto;
    padding: 2rem clamp(1rem, 3vw, 1.6rem) 2.4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
  }

  .site-footer div {
    display: grid;
    gap: 0.12rem;
  }

  .site-footer strong {
    color: var(--text);
  }

  .site-footer span,
  .site-footer p {
    overflow-wrap: anywhere;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: "";
    width: 1.6rem;
    height: 1px;
    background: currentColor;
  }

  .page-title {
    font-family: ui-serif, "Songti SC", "Noto Serif CJK SC", Georgia, serif;
    font-size: clamp(2.15rem, 6vw, 4.6rem);
    line-height: 1.02;
    letter-spacing: 0;
    max-width: 12ch;
    overflow-wrap: anywhere;
  }

  .page-intro {
    max-width: 54rem;
    display: grid;
    gap: 1rem;
    margin: 0 0 clamp(2rem, 5vw, 3.5rem);
  }

  .lede {
    max-width: 46rem;
    color: var(--text-secondary);
    font-size: clamp(1.02rem, 2vw, 1.2rem);
    line-height: 1.8;
    overflow-wrap: anywhere;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-heading h2 {
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .section-heading p {
    max-width: 30rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .button {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.68rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--text);
    background: color-mix(in srgb, var(--surface-strong) 78%, transparent);
    text-decoration: none;
    font-weight: 700;
    line-height: 1.15;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.35) inset;
    transition:
      transform 180ms var(--ease),
      box-shadow 180ms var(--ease),
      border-color 180ms var(--ease),
      background 180ms var(--ease);
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: var(--shadow-soft);
  }

  .button.primary {
    background: var(--text);
    border-color: var(--text);
    color: var(--bg-elevated);
  }

  .button.subtle {
    color: var(--accent);
  }

  .meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    color: var(--text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .meta-line span,
  .meta-line time {
    display: inline-flex;
    align-items: center;
    min-height: 1.65rem;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 74%, transparent);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .tag-chip {
    min-height: 1.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.24rem 0.58rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--bg-elevated) 78%, transparent);
    color: var(--text-secondary);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    overflow-wrap: anywhere;
    transition:
      transform 180ms var(--ease),
      border-color 180ms var(--ease),
      color 180ms var(--ease),
      background 180ms var(--ease);
  }

  .tag-chip:hover,
  .tag-chip.featured {
    border-color: color-mix(in srgb, var(--accent) 58%, var(--border));
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 9%, var(--bg-elevated));
  }

  .tag-chip:hover {
    transform: translateY(-1px);
  }

  .empty-state {
    padding: clamp(1.2rem, 4vw, 2rem);
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--surface) 76%, transparent);
    color: var(--text-secondary);
    line-height: 1.75;
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-main > * {
      animation: enter-page 520ms var(--ease) both;
    }

    @keyframes enter-page {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }

  @media (max-width: 760px) {
    .site-header {
      position: static;
    }

    .site-nav {
      align-items: flex-start;
      flex-direction: column;
      padding-block: 0.9rem;
    }

    .links {
      width: 100%;
      justify-content: flex-start;
    }

    .links a {
      min-height: 2.55rem;
      padding-inline: 0.68rem;
    }

    .site-main {
      padding-top: 1.2rem;
    }

    .site-footer {
      align-items: flex-start;
      flex-direction: column;
      padding-block: 1.5rem 2rem;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 430px) {
    .logo-mark {
      width: 2.25rem;
      height: 2.25rem;
    }

    .logo-text small {
      display: none;
    }

    .links a {
      font-size: 0.88rem;
    }

    .button {
      width: 100%;
    }
  }
</style>
