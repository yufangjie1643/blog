---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="首页">
  <section class="hero">
    <div class="avatar">🔬</div>
    <h1>yufangjie1643</h1>
    <p class="tagline">西南交通大学 · 力学与航空航天学院</p>
    <p class="desc">计算力学 | 复合材料损伤力学 | 纺织结构建模 | 边坡抗震分析</p>
    <div class="actions">
      <a href="/projects" class="btn primary">查看项目</a>
      <a href="/blog" class="btn">阅读文章</a>
    </div>
  </section>

  <section class="posts">
    <div class="section-header">
      <h2>最新文章</h2>
      <a href="/blog" class="more">查看全部 →</a>
    </div>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`}>
            <span class="title">{post.data.title}</span>
            <span class="date">
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .avatar {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: var(--accent);
    font-weight: 500;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.6rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s;
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--bg);
  }

  .btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn.primary {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  .btn.primary:hover {
    background: var(--accent-light);
    border-color: var(--accent-light);
  }

  .posts {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.25rem;
    color: var(--text-secondary);
  }

  .more {
    font-size: 0.9rem;
    color: var(--accent);
    text-decoration: none;
  }

  .more:hover {
    text-decoration: underline;
  }

  .posts ul {
    list-style: none;
    padding: 0;
  }

  .posts li {
    margin-bottom: 0.75rem;
  }

  .posts a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .posts a:hover {
    background: var(--bg-secondary);
  }

  .posts .title {
    font-weight: 500;
  }

  .posts .date {
    color: var(--text-secondary);
    font-size: 0.875rem;
    white-space: nowrap;
    margin-left: 1rem;
  }
</style>
