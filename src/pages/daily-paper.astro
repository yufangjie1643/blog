---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { dailyPaperTag } from '../data/tags';
import { getBlogHref, getFallbackTime, getTimestamp, isPublished, sortPosts } from '../lib/content';

const posts = sortPosts(
  (await getCollection('blog'))
    .filter(isPublished)
    .filter((post) => (post.data.tags ?? []).includes(dailyPaperTag)),
);
---

<Layout title="每日论文精读" description="每日论文精读文章归档。">
  <section class="page-intro">
    <p class="eyebrow">Daily Paper Reading</p>
    <h1 class="page-title">每日论文精读</h1>
    <p class="lede">
      用固定节奏记录论文问题、方法、实验结论和可借鉴的实现细节。
    </p>
    <div class="tag-list" aria-label="页面标签">
      <span class="tag-chip featured">{dailyPaperTag}</span>
    </div>
  </section>

  {
    posts.length > 0 ? (
      <section class="paper-list" aria-label="每日论文精读文章">
        {posts.map((post, index) => (
          <article class="paper-card">
            <a href={getBlogHref(post)}>
              <span class="paper-index">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <time datetime={post.data.pubDate.toISOString()} data-timestamp={getTimestamp(post.data.pubDate)}>
                  {getFallbackTime(post.data.pubDate)}
                </time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                {post.data.paper && (
                  <p class="paper-source">
                    {post.data.paper.authors.join(', ')}
                    {post.data.paper.venue && ` · ${post.data.paper.venue}`}
                    {post.data.paper.year && ` · ${post.data.paper.year}`}
                  </p>
                )}
              </div>
            </a>
          </article>
        ))}
      </section>
    ) : (
      <p class="empty-state">还没有归档文章，后续论文精读内容会出现在这里。</p>
    )
  }
</Layout>

<style>
  .paper-list {
    display: grid;
    gap: 0.85rem;
  }

  .paper-card a {
    min-width: 0;
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1rem;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background:
      linear-gradient(120deg, rgba(255, 255, 255, 0.38), transparent),
      var(--surface);
    color: inherit;
    text-decoration: none;
    transition:
      transform 180ms var(--ease),
      border-color 180ms var(--ease),
      box-shadow 180ms var(--ease),
      background 180ms var(--ease);
  }

  .paper-card a:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--surface-strong);
    box-shadow: var(--shadow-soft);
  }

  .paper-index {
    width: 3.1rem;
    height: 3.1rem;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--accent);
    background: color-mix(in srgb, var(--bg-elevated) 82%, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-weight: 800;
    line-height: 1;
  }

  .paper-card time {
    color: var(--text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
  }

  .paper-card h2 {
    margin-top: 0.2rem;
    color: var(--text);
    font-size: clamp(1.14rem, 2.4vw, 1.55rem);
    line-height: 1.32;
    overflow-wrap: anywhere;
  }

  .paper-card p {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    line-height: 1.75;
    overflow-wrap: anywhere;
  }

  .paper-card .paper-source {
    color: var(--text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    line-height: 1.55;
  }

  @media (max-width: 560px) {
    .paper-card a {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 1rem;
    }

    .paper-index {
      width: fit-content;
      height: auto;
      padding: 0.35rem 0.55rem;
    }
  }
</style>
