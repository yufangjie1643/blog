---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  return a.data.name.localeCompare(b.data.name);
});
---

<Layout title="项目" description="yufangjie1643 的开源项目，覆盖计算力学、复合材料建模、边坡动力响应和目标跟踪。">
  <section class="page-intro">
    <p class="eyebrow">Open Source Bench</p>
    <h1 class="page-title">开源项目</h1>
    <p class="lede">
      这些项目连接了研究原型、工程脚本和可复现实验。每个仓库都对应一条问题线索：建模、求解、前处理或算法验证。
    </p>
  </section>

  <section class="project-grid" aria-label="项目列表">
    {
      projects.map((project) => (
        <a href={project.data.url} target="_blank" rel="noopener" class="project-card">
          <div class="card-topline">
            <span>{project.data.area}</span>
            <strong>{project.data.lang}</strong>
          </div>
          <h2>{project.data.name}</h2>
          <p class="status">{project.data.status}</p>
          <p class="description">{project.data.description}</p>
          <div class="tags" aria-label={`${project.data.name} 标签`}>
            {
              project.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))
            }
          </div>
        </a>
      ))
    }
  </section>
</Layout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card {
    min-width: 0;
    min-height: 18rem;
    display: flex;
    flex-direction: column;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: inherit;
    text-decoration: none;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.4), transparent 52%),
      var(--surface);
    box-shadow: var(--shadow-soft);
    transition:
      transform 180ms var(--ease),
      border-color 180ms var(--ease),
      background 180ms var(--ease),
      box-shadow 180ms var(--ease);
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    background: var(--surface-strong);
    box-shadow: var(--shadow);
  }

  .card-topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.7rem;
    color: var(--text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    line-height: 1.35;
  }

  .card-topline span {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .card-topline strong {
    flex: 0 0 auto;
    color: var(--accent-2);
    font-weight: 800;
    text-align: right;
  }

  .project-card h2 {
    margin-top: 1.8rem;
    color: var(--text);
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    line-height: 1.15;
    overflow-wrap: anywhere;
  }

  .status {
    width: fit-content;
    margin-top: 0.5rem;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--accent);
    background: color-mix(in srgb, var(--bg-elevated) 76%, transparent);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .description {
    margin-top: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.72;
    font-size: 0.95rem;
    overflow-wrap: anywhere;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 1.2rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    padding: 0.22rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--bg-elevated) 74%, transparent);
    color: var(--text-secondary);
    font-size: 0.78rem;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  @media (max-width: 960px) {
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      min-height: 0;
    }
  }
</style>
